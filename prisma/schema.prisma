// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  COLLECTOR
  ADMIN
}

enum Status {
  PENDING
  COMPLETED
  MISSED
}

model User {
  id                String     @id @default(uuid())
  name              String?
  email             String     @unique
  role              Role       @default(USER)
  active            Boolean    @default(true)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  assignedSchedules Schedule[] @relation("CollectorSchedules")
  schedules         Schedule[] @relation("UserSchedules")
  aiAnalyses        AIAnalysis[]

  @@index([role])
}

model Schedule {
  id                  String   @id @default(uuid())
  userId              String
  user                User     @relation("UserSchedules", fields: [userId], references: [id])
  collectorId         String?
  collector           User?    @relation("CollectorSchedules", fields: [collectorId], references: [id])
  date                DateTime
  status              Status   @default(PENDING)
  wasteVolume         Float
  wasteType           String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([status])
  @@index([date])
  @@index([collectorId])
}

model AIAnalysis {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  isCorrect  Boolean
  createdAt  DateTime @default(now())
}
